# Anthropic API Key - https://console.anthropic.com/
# 1. Bu dosyayı kopyala: cp .env.example .env
# 2. Kendi key'ini yapıştır
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub Personal Access Token (opsiyonel - rate limit artırmak için)
# https://github.com/settings/tokens adresinden oluştur
GITHUB_TOKEN=
